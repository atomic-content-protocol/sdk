---
// Standalone playground page — no StarlightPage wrapper needed.
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ACP Playground | Atomic Content Protocol</title>
  <style>
    /* ---- Reset / base ---- */
    *, *::before, *::after { box-sizing: border-box; }

    :root {
      color-scheme: dark;
      --accent: #7c3aed;
      --accent-light: #a78bfa;
      --bg: #0f0f1a;
      --bg-nav: #15152a;
      --bg-sidebar: #1a1a2e;
      --hairline: #2a2a40;
      --text: #e2e2f0;
      --text-muted: #9898bb;
      --text-dim: #6666aa;
      --green: #10b981;
      --red: #ef4444;
      --font-mono: ui-monospace, "Cascadia Code", Consolas, monospace;
    }

    @media (prefers-color-scheme: light) {
      :root {
        color-scheme: light;
        --accent: #6d28d9;
        --accent-light: #8b5cf6;
        --bg: #ffffff;
        --bg-nav: #f8f8fe;
        --bg-sidebar: #f0f0fa;
        --hairline: #e0e0f0;
        --text: #1a1a2e;
        --text-muted: #4a4a70;
        --text-dim: #9898bb;
        --green: #059669;
        --red: #dc2626;
      }
    }

    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: var(--bg);
      color: var(--text);
      margin: 0;
      padding: 0;
      line-height: 1.6;
    }

    a { color: var(--accent-light); }
    a:hover { color: var(--accent); }
    code { font-family: var(--font-mono); font-size: 0.88em; }

    /* ---- Nav bar ---- */
    .pg-nav {
      background: var(--bg-sidebar);
      border-bottom: 1px solid var(--hairline);
      padding: 0.75rem 2rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    .pg-nav-brand {
      font-weight: 700;
      font-size: 0.95rem;
      color: var(--text);
      text-decoration: none;
    }

    .pg-nav-back {
      font-size: 0.85rem;
      color: var(--text-muted);
      text-decoration: none;
    }

    .pg-nav-back:hover { color: var(--accent-light); }

    /* ---- Page wrapper ---- */
    .pg-wrap {
      max-width: 860px;
      margin: 0 auto;
      padding: 1.5rem 2rem 4rem;
    }

    /* ---- Hero ---- */
    .pg-hero {
      text-align: center;
      padding: 2.5rem 0 3rem;
    }

    .pg-hero h1 {
      font-size: 2rem;
      font-weight: 700;
      margin: 0 0 0.5rem;
      color: var(--accent-light);
    }

    .pg-hero p {
      font-size: 1.05rem;
      color: var(--text-muted);
      max-width: 600px;
      margin: 0 auto;
    }

    /* ---- Section headings ---- */
    .pg-section-title {
      font-size: 1.3rem;
      font-weight: 700;
      margin: 2.5rem 0 1rem;
      color: var(--text);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .pg-section-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--hairline);
    }

    /* ---- Example tabs ---- */
    .pg-tabs {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .pg-tab {
      padding: 0.4rem 1rem;
      border-radius: 999px;
      border: 1px solid var(--hairline);
      background: transparent;
      color: var(--text-muted);
      cursor: pointer;
      font-size: 0.85rem;
      font-weight: 500;
      transition: all 0.15s;
    }

    .pg-tab:hover {
      border-color: var(--accent);
      color: var(--accent-light);
    }

    .pg-tab.active {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }

    /* ---- ACO card ---- */
    .aco-card {
      border: 1px solid var(--hairline);
      border-radius: 0.75rem;
      overflow: hidden;
      background: var(--bg-nav);
      display: none;
    }

    .aco-card.visible { display: block; }

    .aco-card-header {
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid var(--hairline);
      background: var(--bg-sidebar);
      display: flex;
      gap: 1rem;
      align-items: flex-start;
    }

    .aco-card-avatar {
      width: 56px;
      height: 56px;
      border-radius: 0.5rem;
      object-fit: cover;
      flex-shrink: 0;
      background: var(--hairline);
    }

    .aco-card-avatar-placeholder {
      width: 56px;
      height: 56px;
      border-radius: 0.5rem;
      background: linear-gradient(135deg, var(--accent), var(--accent-light));
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.4rem;
    }

    .aco-card-title-block {
      flex: 1;
      min-width: 0;
    }

    .aco-card-title {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--text);
      margin: 0 0 0.25rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .aco-card-url {
      font-size: 0.78rem;
      color: var(--text-dim);
      text-decoration: none;
      display: block;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .aco-card-url:hover { color: var(--accent-light); }

    .aco-card-body {
      padding: 1.25rem 1.5rem;
      display: grid;
      gap: 1rem;
    }

    /* Summary */
    .aco-summary {
      background: rgba(124, 58, 237, 0.08);
      border-left: 3px solid var(--accent);
      border-radius: 0 0.4rem 0.4rem 0;
      padding: 0.75rem 1rem;
      font-size: 0.9rem;
      color: var(--text);
      line-height: 1.6;
    }

    /* Badges row */
    .aco-meta-row {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .aco-badge {
      padding: 0.2rem 0.65rem;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .aco-badge-classification {
      background: rgba(124, 58, 237, 0.15);
      color: var(--accent-light);
      border: 1px solid rgba(124, 58, 237, 0.3);
    }

    .aco-badge-lang {
      background: rgba(16, 185, 129, 0.15);
      color: var(--green);
      border: 1px solid rgba(16, 185, 129, 0.3);
    }

    /* Tags */
    .aco-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
    }

    .aco-tag {
      background: var(--bg);
      border: 1px solid var(--hairline);
      border-radius: 0.3rem;
      padding: 0.2rem 0.55rem;
      font-size: 0.78rem;
      color: var(--text-muted);
      font-family: var(--font-mono);
    }

    /* Entities */
    .aco-entities { display: grid; gap: 0.5rem; }

    .aco-entity {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 0.5rem 0.75rem;
      align-items: center;
    }

    .aco-entity-type {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-dim);
      width: 6rem;
      font-weight: 600;
    }

    .aco-entity-name {
      font-size: 0.88rem;
      color: var(--text);
      font-weight: 500;
    }

    .aco-entity-bar-wrap {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      min-width: 100px;
    }

    .aco-entity-bar {
      flex: 1;
      height: 4px;
      border-radius: 999px;
      background: var(--hairline);
      overflow: hidden;
    }

    .aco-entity-bar-fill {
      height: 100%;
      border-radius: 999px;
      background: var(--accent);
      transition: width 0.6s ease;
    }

    .aco-entity-conf {
      font-size: 0.72rem;
      color: var(--text-dim);
      width: 2.5rem;
      text-align: right;
      font-family: var(--font-mono);
    }

    /* Tokens */
    .aco-tokens { display: flex; gap: 1rem; flex-wrap: wrap; }

    .aco-token-item {
      background: var(--bg);
      border: 1px solid var(--hairline);
      border-radius: 0.4rem;
      padding: 0.35rem 0.7rem;
      font-size: 0.8rem;
    }

    .aco-token-label {
      color: var(--text-dim);
      font-size: 0.7rem;
      display: block;
      margin-bottom: 0.1rem;
    }

    .aco-token-value {
      font-family: var(--font-mono);
      font-weight: 700;
      color: var(--text);
    }

    /* Provenance collapsible */
    .aco-prov-toggle {
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
      font-size: 0.82rem;
      color: var(--text-dim);
      display: flex;
      align-items: center;
      gap: 0.3rem;
      transition: color 0.15s;
    }

    .aco-prov-toggle:hover { color: var(--accent-light); }

    .aco-prov-toggle .arrow {
      display: inline-block;
      transition: transform 0.2s;
    }

    .aco-prov-toggle.open .arrow { transform: rotate(90deg); }

    .aco-prov-content {
      display: none;
      margin-top: 0.5rem;
      padding: 0.75rem;
      background: var(--bg);
      border: 1px solid var(--hairline);
      border-radius: 0.4rem;
      font-size: 0.78rem;
      font-family: var(--font-mono);
      color: var(--text-muted);
      line-height: 1.7;
      white-space: pre;
    }

    .aco-prov-content.open { display: block; }

    /* Raw YAML toggle */
    .aco-yaml-toggle {
      background: none;
      border: 1px solid var(--hairline);
      padding: 0.3rem 0.8rem;
      border-radius: 0.35rem;
      cursor: pointer;
      font-size: 0.78rem;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      gap: 0.3rem;
      transition: all 0.15s;
    }

    .aco-yaml-toggle:hover {
      border-color: var(--accent);
      color: var(--accent-light);
    }

    .aco-yaml-block { display: none; margin-top: 0.5rem; }
    .aco-yaml-block.open { display: block; }

    .aco-yaml-block pre {
      margin: 0;
      background: var(--bg);
      border: 1px solid var(--hairline);
      border-radius: 0.4rem;
      padding: 1rem;
      overflow-x: auto;
      font-size: 0.78rem;
      line-height: 1.6;
      color: var(--text-muted);
      white-space: pre;
    }

    /* Section label */
    .aco-section-label {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-dim);
      margin-bottom: 0.35rem;
    }

    /* Divider */
    hr {
      border: none;
      border-top: 1px solid var(--hairline);
      margin: 2rem 0;
    }

    /* ---- Interactive form ---- */
    .pg-form {
      border: 1px solid var(--hairline);
      border-radius: 0.75rem;
      padding: 1.5rem;
      background: var(--bg-nav);
      display: grid;
      gap: 1rem;
    }

    .pg-form label {
      display: block;
      font-size: 0.85rem;
      font-weight: 600;
      margin-bottom: 0.35rem;
      color: var(--text);
    }

    .pg-form textarea,
    .pg-form input[type="password"],
    .pg-form input[type="text"] {
      width: 100%;
      border: 1px solid var(--hairline);
      border-radius: 0.4rem;
      padding: 0.65rem 0.85rem;
      background: var(--bg);
      color: var(--text);
      font-size: 0.88rem;
      font-family: inherit;
      resize: vertical;
      transition: border-color 0.15s;
    }

    .pg-form textarea:focus,
    .pg-form input:focus {
      outline: none;
      border-color: var(--accent);
    }

    .pg-form textarea {
      min-height: 160px;
      font-family: var(--font-mono);
      font-size: 0.82rem;
    }

    .pg-form-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 0.75rem;
      align-items: flex-end;
    }

    .pg-key-note {
      font-size: 0.75rem;
      color: var(--text-dim);
      margin-top: 0.3rem;
      display: flex;
      align-items: center;
      gap: 0.3rem;
    }

    .pg-btn {
      padding: 0.65rem 1.5rem;
      border-radius: 0.4rem;
      border: none;
      cursor: pointer;
      font-size: 0.88rem;
      font-weight: 700;
      background: var(--accent);
      color: #fff;
      transition: opacity 0.15s;
      white-space: nowrap;
    }

    .pg-btn:hover:not(:disabled) { opacity: 0.85; }

    .pg-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    /* Status / error */
    .pg-status {
      font-size: 0.85rem;
      padding: 0.6rem 0.9rem;
      border-radius: 0.4rem;
      display: none;
    }

    .pg-status.info {
      display: block;
      background: rgba(124, 58, 237, 0.1);
      color: var(--accent-light);
      border: 1px solid rgba(124, 58, 237, 0.25);
    }

    .pg-status.error {
      display: block;
      background: rgba(239, 68, 68, 0.1);
      color: var(--red);
      border: 1px solid rgba(239, 68, 68, 0.25);
    }

    /* Live result area */
    #pg-result { display: none; }
    #pg-result.visible { display: block; }

    /* Spinner */
    @keyframes spin { to { transform: rotate(360deg); } }

    .pg-spinner {
      display: inline-block;
      width: 14px;
      height: 14px;
      border: 2px solid currentColor;
      border-right-color: transparent;
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
      vertical-align: middle;
    }

    /* Token economics box */
    .aco-economics {
      margin-top: 1rem;
      padding: 1rem;
      border: 1px solid var(--accent);
      border-radius: 8px;
      background: color-mix(in srgb, var(--accent) 5%, var(--bg));
      font-family: var(--font-mono);
      font-size: 0.85rem;
      line-height: 1.6;
    }
    .aco-economics-title {
      font-weight: 600;
      color: var(--accent-light);
      margin-bottom: 0.5rem;
    }
    .aco-economics-row {
      display: flex;
      justify-content: space-between;
    }
    .aco-economics-label { color: var(--text-muted); }
    .aco-economics-value { color: var(--text); font-weight: 500; }

    /* Responsive */
    @media (max-width: 600px) {
      .pg-wrap { padding: 1rem; }
      .pg-form-row { grid-template-columns: 1fr; }
      .aco-entity { grid-template-columns: auto 1fr; }
      .aco-entity-bar-wrap { grid-column: 2; }
    }
  </style>
</head>
<body>

  <nav class="pg-nav">
    <a class="pg-nav-brand" href="/">Atomic Content Protocol</a>
    <a class="pg-nav-back" href="/getting-started/what-is-acp">&larr; Back to docs</a>
  </nav>

  <div class="pg-wrap">

    <div class="pg-hero">
      <h1>ACP Playground</h1>
      <p>Pre-enriched examples show what a fully structured Atomic Content Object looks like. Scroll down to enrich your own text live.</p>
    </div>

    <div class="pg-section-title">Pre-enriched examples</div>

    <div class="pg-tabs" role="tablist">
      <button class="pg-tab active" role="tab" onclick="showExample('profile')" id="tab-profile">Stacklist profile</button>
      <button class="pg-tab" role="tab" onclick="showExample('article')" id="tab-article">Tech article</button>
      <button class="pg-tab" role="tab" onclick="showExample('analysis')" id="tab-analysis">Research paper</button>
    </div>

    <!-- Example 1: Stacklist profile -->
    <div class="aco-card visible" id="ex-profile">
      <div class="aco-card-header">
        <img
          class="aco-card-avatar"
          src="https://ucarecdn.com/1ed35c46-aab6-4f6c-8667-1f3de48eedb5/-/crop/1024x1365/0,159/-/scale_crop/112x112/smart/"
          alt="Martina Zrnec"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <div class="aco-card-avatar-placeholder" style="display:none">&#128100;</div>
        <div class="aco-card-title-block">
          <div class="aco-card-title">Martina Zrnec | Stacklist</div>
          <a class="aco-card-url" href="https://stacklist.app/martina" target="_blank" rel="noopener">stacklist.app/martina</a>
        </div>
      </div>
      <div class="aco-card-body">

        <div>
          <div class="aco-section-label">Summary</div>
          <div class="aco-summary">Martina Zrnec is the Co-founder &amp; CTO of Stacklist, a curation platform specializing in tech stack innovations, startup resources, and global travel guides. Her curated collections span Croatian heritage, food culture, entrepreneurship, and tools for modern builders.</div>
        </div>

        <div class="aco-meta-row">
          <span class="aco-badge aco-badge-classification">reference</span>
          <span class="aco-badge aco-badge-lang">en</span>
        </div>

        <div>
          <div class="aco-section-label">Tags</div>
          <div class="aco-tags">
            <span class="aco-tag">curation</span>
            <span class="aco-tag">startup-tools</span>
            <span class="aco-tag">tech-stack</span>
            <span class="aco-tag">travel-guides</span>
            <span class="aco-tag">croatian-heritage</span>
            <span class="aco-tag">food-culture</span>
            <span class="aco-tag">entrepreneurship</span>
          </div>
        </div>

        <div>
          <div class="aco-section-label">Key entities</div>
          <div class="aco-entities">
            <div class="aco-entity">
              <span class="aco-entity-type">person</span>
              <span class="aco-entity-name">Martina Zrnec</span>
              <div class="aco-entity-bar-wrap"><div class="aco-entity-bar"><div class="aco-entity-bar-fill" style="width:99%"></div></div><span class="aco-entity-conf">0.99</span></div>
            </div>
            <div class="aco-entity">
              <span class="aco-entity-type">organization</span>
              <span class="aco-entity-name">Stacklist</span>
              <div class="aco-entity-bar-wrap"><div class="aco-entity-bar"><div class="aco-entity-bar-fill" style="width:99%"></div></div><span class="aco-entity-conf">0.99</span></div>
            </div>
            <div class="aco-entity">
              <span class="aco-entity-type">location</span>
              <span class="aco-entity-name">Zagreb</span>
              <div class="aco-entity-bar-wrap"><div class="aco-entity-bar"><div class="aco-entity-bar-fill" style="width:95%"></div></div><span class="aco-entity-conf">0.95</span></div>
            </div>
            <div class="aco-entity">
              <span class="aco-entity-type">location</span>
              <span class="aco-entity-name">Croatia</span>
              <div class="aco-entity-bar-wrap"><div class="aco-entity-bar"><div class="aco-entity-bar-fill" style="width:95%"></div></div><span class="aco-entity-conf">0.95</span></div>
            </div>
            <div class="aco-entity">
              <span class="aco-entity-type">location</span>
              <span class="aco-entity-name">Barcelona</span>
              <div class="aco-entity-bar-wrap"><div class="aco-entity-bar"><div class="aco-entity-bar-fill" style="width:90%"></div></div><span class="aco-entity-conf">0.90</span></div>
            </div>
          </div>
        </div>

        <div>
          <div class="aco-section-label">Token counts</div>
          <div class="aco-tokens">
            <div class="aco-token-item"><span class="aco-token-label">approximate</span><span class="aco-token-value">1,230</span></div>
            <div class="aco-token-item"><span class="aco-token-label">cl100k</span><span class="aco-token-value">998</span></div>
          </div>
        </div>

        <div>
          <button class="aco-prov-toggle" onclick="toggleProv(this)">
            <span class="arrow">&#9658;</span> Provenance
          </button>
          <div class="aco-prov-content">tags:      &#123; model: "claude-haiku-4-5", confidence: 0.85 &#125;
summary:   &#123; model: "claude-haiku-4-5", confidence: 0.91 &#125;
entities:  &#123; model: "claude-haiku-4-5", confidence: 0.80 &#125;</div>
        </div>

        <div style="display:flex;justify-content:flex-end">
          <button class="aco-yaml-toggle" onclick="toggleYaml(this)">
            &lt;/&gt; Raw YAML
          </button>
        </div>
        <div class="aco-yaml-block">
          <pre>title: "Martina Zrnec | Stacklist"
source_url: "https://stacklist.app/martina"
language: en
tags:
  - curation
  - startup-tools
  - tech-stack
  - travel-guides
  - croatian-heritage
  - food-culture
  - entrepreneurship
summary: &gt;
  Martina Zrnec is the Co-founder &amp; CTO of Stacklist, a curation platform
  specializing in tech stack innovations, startup resources, and global
  travel guides. Her curated collections span Croatian heritage, food
  culture, entrepreneurship, and tools for modern builders.
classification: reference
key_entities:
  - &#123; type: person,       name: "Martina Zrnec", confidence: 0.99 &#125;
  - &#123; type: organization, name: "Stacklist",      confidence: 0.99 &#125;
  - &#123; type: location,     name: "Zagreb",         confidence: 0.95 &#125;
  - &#123; type: location,     name: "Croatia",        confidence: 0.95 &#125;
  - &#123; type: location,     name: "Barcelona",      confidence: 0.90 &#125;
token_counts:
  approximate: 1230
  cl100k: 998
provenance:
  tags:     &#123; model: "claude-haiku-4-5", confidence: 0.85 &#125;
  summary:  &#123; model: "claude-haiku-4-5", confidence: 0.91 &#125;
  entities: &#123; model: "claude-haiku-4-5", confidence: 0.80 &#125;</pre>
        </div>

        <div class="aco-economics">
          <div class="aco-economics-title">Token Economics</div>
          <div class="aco-economics-row"><span class="aco-economics-label">Enrichment cost:</span><span class="aco-economics-value">~$0.0004</span></div>
          <div class="aco-economics-row"><span class="aco-economics-label">Original content:</span><span class="aco-economics-value">1,230 tokens</span></div>
