  <script is:inline>
    // ===================================================================
    // Input mode toggle (URL vs Text)
    // ===================================================================
    var currentInputMode = 'url';

    function setInputMode(mode) {
      currentInputMode = mode;
      document.getElementById('pg-url-input').style.display = mode === 'url' ? 'block' : 'none';
      document.getElementById('pg-text-input').style.display = mode === 'text' ? 'block' : 'none';
      document.getElementById('mode-url').classList.toggle('active', mode === 'url');
      document.getElementById('mode-text').classList.toggle('active', mode === 'text');
    }

    // ===================================================================
    // Fetch URL content via public CORS proxy
    // ===================================================================
    async function fetchUrlContent(url) {
      // Try multiple CORS proxies
      var proxies = [
        'https://api.allorigins.win/raw?url=',
        'https://corsproxy.io/?',
      ];

      var html = null;
      for (var i = 0; i < proxies.length; i++) {
        try {
          var resp = await fetch(proxies[i] + encodeURIComponent(url), { signal: AbortSignal.timeout(10000) });
          if (resp.ok) {
            html = await resp.text();
            break;
          }
        } catch(e) { /* try next proxy */ }
      }

      if (!html) throw new Error('Could not fetch URL. Try pasting the content directly instead.');

      // Extract metadata
      var titleMatch = html.match(/<title[^>]*>([^<]+)<\/title>/i);
      var ogTitleMatch = html.match(/<meta[^>]*property="og:title"[^>]*content="([^"]+)"/i)
        || html.match(/<meta[^>]*content="([^"]+)"[^>]*property="og:title"/i);
      var ogDescMatch = html.match(/<meta[^>]*property="og:description"[^>]*content="([^"]+)"/i)
        || html.match(/<meta[^>]*content="([^"]+)"[^>]*property="og:description"/i);
      var metaDescMatch = html.match(/<meta[^>]*name="description"[^>]*content="([^"]+)"/i);
      var ogImageMatch = html.match(/<meta[^>]*property="og:image"[^>]*content="([^"]+)"/i)
        || html.match(/<meta[^>]*content="([^"]+)"[^>]*property="og:image"/i);

      var title = (ogTitleMatch && ogTitleMatch[1]) || (titleMatch && titleMatch[1]) || url;
      var desc = (ogDescMatch && ogDescMatch[1]) || (metaDescMatch && metaDescMatch[1]) || '';
      var ogImage = ogImageMatch ? ogImageMatch[1] : null;

      // Strip HTML for body
      var bodyText = html
        .replace(/<script[^>]*>[\s\S]*?<\/script>/gi, '')
        .replace(/<style[^>]*>[\s\S]*?<\/style>/gi, '')
        .replace(/<nav[^>]*>[\s\S]*?<\/nav>/gi, '')
        .replace(/<header[^>]*>[\s\S]*?<\/header>/gi, '')
        .replace(/<footer[^>]*>[\s\S]*?<\/footer>/gi, '')
        .replace(/<[^>]+>/g, ' ')
        .replace(/\s+/g, ' ')
        .trim()
        .slice(0, 5000);

      var body = desc ? desc + '\n\n' + bodyText : bodyText;

      return { title: title.trim(), body: body, ogImage: ogImage, url: url };
    }

    // ===================================================================
    // Tab switching
    // ===================================================================
    function showExample(id) {
      ['profile','article','analysis'].forEach(function(ex) {
        document.getElementById('ex-' + ex).classList.remove('visible');
        document.getElementById('tab-' + ex).classList.remove('active');
      });
      document.getElementById('ex-' + id).classList.add('visible');
      document.getElementById('tab-' + id).classList.add('active');
    }

    // ===================================================================
    // Collapsible: provenance
    // ===================================================================
    function toggleProv(btn) {
      btn.classList.toggle('open');
      btn.nextElementSibling.classList.toggle('open');
    }

    // ===================================================================
    // Collapsible: raw YAML
    // ===================================================================
    function toggleYaml(btn) {
      var block = btn.closest('.aco-card-body').querySelector('.aco-yaml-block');
      block.classList.toggle('open');
      btn.textContent = block.classList.contains('open') ? '\u2715 Hide YAML' : '</> Raw YAML';
    }

    // ===================================================================
    // Persist API key
    // ===================================================================
    (function() {
      try {
        var stored = localStorage.getItem('acp_pg_apikey');
        if (stored) document.getElementById('pg-apikey').value = stored;
      } catch(e) {}
    })();

    document.getElementById('pg-apikey').addEventListener('change', function() {
      try { localStorage.setItem('acp_pg_apikey', this.value); } catch(e) {}
    });

    // ===================================================================
    // Enrich via Anthropic API (direct browser call)
    // ===================================================================
    async function runEnrichment() {
      var apiKey  = document.getElementById('pg-apikey').value.trim();
      var btn     = document.getElementById('pg-enrich-btn');
      var result  = document.getElementById('pg-result');
      var sourceUrl = null;
      var ogImage = null;

      if (apiKey) {
        try { localStorage.setItem('acp_pg_apikey', apiKey); } catch(e) {}
      }

      if (!apiKey || !apiKey.startsWith('sk-ant-')) {
        showStatus('error', 'Please enter a valid Anthropic API key (starts with sk-ant-).'); return;
      }

      var title = '';
      var body = '';

      if (currentInputMode === 'url') {
        var urlValue = document.getElementById('pg-url').value.trim();
        if (!urlValue) { showStatus('error', 'Please enter a URL to enrich.'); return; }
        if (!urlValue.startsWith('http')) urlValue = 'https://' + urlValue;

        btn.disabled = true;
        btn.innerHTML = '<span class="pg-spinner"></span> Fetching\u2026';
        showStatus('info', 'Fetching page content\u2026');

        try {
          var fetched = await fetchUrlContent(urlValue);
          title = fetched.title;
          body = fetched.body;
          sourceUrl = fetched.url;
          ogImage = fetched.ogImage;
          showStatus('info', 'Page fetched (' + body.length + ' chars). Enriching\u2026');
        } catch(e) {
          btn.disabled = false;
          btn.innerHTML = 'Enrich';
          showStatus('error', e.message || 'Failed to fetch URL.');
          return;
        }
      } else {
        var content = document.getElementById('pg-content').value.trim();
        if (!content) { showStatus('error', 'Please paste some content to enrich.'); return; }

        // Extract title from first non-empty line
        var lines = content.split('\n');
        body = content;
        for (var i = 0; i < lines.length; i++) {
          var line = lines[i].trim().replace(/^#+\s*/, '');
          if (line) {
            title = line.length > 120 ? line.slice(0, 120) + '\u2026' : line;
            body = lines.slice(i + 1).join('\n').trim();
            break;
          }
        }
        if (!body) body = content;
      }

      btn.disabled = true;
      btn.innerHTML = '<span class="pg-spinner"></span> Enriching\u2026';
      result.classList.remove('visible');
      showStatus('info', 'Calling Anthropic API\u2026');

      var prompt = 'Analyze the following content and extract structured enrichment data.\n\nTitle: ' +
        truncate(title, 200) + '\nContent:\n' + truncate(body, 4000) +
        '\n\nExtract:\n1. Tags: 3-7 relevant keywords (lowercase, single words or hyphenated phrases)\n' +
        '2. Summary: exactly 2 sentences, max 500 characters, starting with the subject\n' +
        '3. Classification: one of reference, framework, memo, checklist, notes, transcript, snippet, code, tutorial, analysis, other\n' +
        '4. Key entities: named entities with type (person, organization, technology, concept, location, event), name, and confidence (0.0-1.0)\n' +
        '5. Language: ISO 639-1 two-letter code (en, de, ja, etc.)';

      var requestBody = {
        model: 'claude-haiku-4-5',
        max_tokens: 1024,
        messages: [{ role: 'user', content: prompt }],
        tools: [{
          name: 'enrich_aco',
          description: 'Extract enrichment data from content',
          input_schema: {
            type: 'object',
            properties: {
              tags: { type: 'array', items: { type: 'string' } },
              summary: { type: 'string' },
              classification: {
                type: 'string',
                enum: ['reference','framework','memo','checklist','notes','transcript','snippet','code','tutorial','analysis','other']
              },
              key_entities: {
                type: 'array',
                items: {
                  type: 'object',
                  properties: {
                    type: { type: 'string' },
                    name: { type: 'string' },
                    confidence: { type: 'number' }
                  },
                  required: ['type','name','confidence']
                }
              },
              language: { type: 'string' }
            },
            required: ['tags','summary','classification','key_entities','language']
          }
        }],
        tool_choice: { type: 'tool', name: 'enrich_aco' }
      };

      try {
        var response = await fetch('https://api.anthropic.com/v1/messages', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'x-api-key': apiKey,
            'anthropic-version': '2023-06-01',
            'anthropic-dangerous-direct-browser-access': 'true'
          },
          body: JSON.stringify(requestBody)
        });

        if (!response.ok) {
          var err = await response.json().catch(function() { return {}; });
          var msg = (err && err.error && err.error.message) ? err.error.message : 'HTTP ' + response.status;
          throw new Error(msg);
        }

        var data = await response.json();
        var toolUse = null;
        for (var i = 0; i < data.content.length; i++) {
          if (data.content[i].type === 'tool_use') { toolUse = data.content[i].input; break; }
        }

        if (!toolUse) throw new Error('No structured output returned from model.');

        var approxTokens = Math.round(body.length / 4);
        renderResult(title, toolUse, approxTokens, sourceUrl, ogImage);
        showStatus('info', 'Enrichment complete \u2014 ' + (data.usage ? data.usage.input_tokens + ' input tokens' : '') + ' via claude-haiku-4-5');
        result.classList.add('visible');

      } catch(err) {
        showStatus('error', 'Error: ' + err.message);
      } finally {
        btn.disabled = false;
        btn.textContent = 'Enrich';
      }
    }

    function truncate(s, max) {
      return s.length > max ? s.slice(0, max) + '\u2026' : s;
    }

    function showStatus(type, msg) {
      var el = document.getElementById('pg-status');
      el.className = 'pg-status ' + type;
      el.textContent = msg;
    }

    function buildEconomicsHtml(contentTokens, frontmatterTokens) {
      frontmatterTokens = frontmatterTokens || 200;
      var inputTokens = contentTokens + 200;
      var outputTokens = 300;
      var haikuCost = (inputTokens * 0.25 + outputTokens * 1.25) / 1000000;
      var savingsPerRead = contentTokens - frontmatterTokens;
      var savingsPercent = savingsPerRead > 0 ? (savingsPerRead / contentTokens * 100).toFixed(0) : 0;
      var readCostPerToken = 2.50 / 1000000;
      var breakEven = savingsPerRead > 0 ? Math.ceil(haikuCost / (savingsPerRead * readCostPerToken)) : 'N/A';
      var costStr = '$' + haikuCost.toFixed(4);
      return '<div class="aco-economics">' +
        '<div class="aco-economics-title">Token Economics</div>' +
        '<div class="aco-economics-row"><span class="aco-economics-label">Enrichment cost:</span><span class="aco-economics-value">~' + costStr + '</span></div>' +
        '<div class="aco-economics-row"><span class="aco-economics-label">Original content:</span><span class="aco-economics-value">' + contentTokens.toLocaleString() + ' tokens</span></div>' +
        '<div class="aco-economics-row"><span class="aco-economics-label">Frontmatter only:</span><span class="aco-economics-value">~' + frontmatterTokens + ' tokens</span></div>' +
        '<div class="aco-economics-row"><span class="aco-economics-label">Savings per read:</span><span class="aco-economics-value">' + savingsPerRead.toLocaleString() + ' tokens (' + savingsPercent + '%)</span></div>' +
        '<div class="aco-economics-row"><span class="aco-economics-label">Break-even:</span><span class="aco-economics-value">' + breakEven + ' reads</span></div>' +
        '</div>';
    }

    function renderResult(title, data, approxTokens, sourceUrl, ogImage) {
      document.getElementById('pg-result-title').textContent = title || 'Enriched ACO';
      var urlLine = document.getElementById('pg-result-ts');
      if (sourceUrl) {
        urlLine.innerHTML = '<a href="' + esc(sourceUrl) + '" target="_blank" style="color:var(--accent-light);text-decoration:none">' + esc(sourceUrl) + '</a>';
      } else {
        urlLine.textContent = new Date().toISOString();
      }

      var body = document.getElementById('pg-result-body');

      var entitiesHtml = '';
      if (data.key_entities && data.key_entities.length) {
        var entityRows = data.key_entities.map(function(e) {
          var pct = Math.round((e.confidence || 0) * 100);
          return '<div class="aco-entity">' +
            '<span class="aco-entity-type">' + esc(e.type) + '</span>' +
            '<span class="aco-entity-name">' + esc(e.name) + '</span>' +
            '<div class="aco-entity-bar-wrap">' +
              '<div class="aco-entity-bar"><div class="aco-entity-bar-fill" style="width:' + pct + '%"></div></div>' +
              '<span class="aco-entity-conf">' + (e.confidence || 0).toFixed(2) + '</span>' +
            '</div></div>';
        }).join('');
        entitiesHtml = '<div><div class="aco-section-label">Key entities</div><div class="aco-entities">' + entityRows + '</div></div>';
      }

      var tagsHtml = '';
      if (data.tags && data.tags.length) {
        var tagPills = data.tags.map(function(t) { return '<span class="aco-tag">' + esc(t) + '</span>'; }).join('');
        tagsHtml = '<div><div class="aco-section-label">Tags</div><div class="aco-tags">' + tagPills + '</div></div>';
      }

      var ts = new Date().toISOString();
      var entitiesYaml = (data.key_entities || []).map(function(e) {
        return '  - { type: ' + e.type + ', name: "' + e.name.replace(/"/g, '\\"') + '", confidence: ' + (e.confidence || 0).toFixed(2) + ' }';
      }).join('\n');

      var rawYaml = 'title: "' + (title || '').replace(/"/g, '\\"') + '"\n' +
        (sourceUrl ? 'source_url: "' + sourceUrl + '"\nsource_type: link\n' : 'source_type: manual\n') +
        (ogImage ? 'media:\n  url: "' + ogImage + '"\n  mime_type: image/jpeg\n' : '') +
        'language: ' + (data.language || 'en') + '\n' +
        'tags:\n' + (data.tags || []).map(function(t){ return '  - ' + t; }).join('\n') + '\n' +
        'summary: >\n  ' + (data.summary || '').replace(/(.{60})/g, '$1\n  ').trim() + '\n' +
        'classification: ' + (data.classification || 'other') + '\n' +
        'key_entities:\n' + (entitiesYaml || '  []') + '\n' +
        'token_counts:\n  approximate: ' + approxTokens + '\n' +
        'provenance:\n' +
        '  tags:     { model: "claude-haiku-4-5", timestamp: "' + ts + '", confidence: 0.85 }\n' +
        '  summary:  { model: "claude-haiku-4-5", timestamp: "' + ts + '", confidence: 0.85 }\n' +
        '  entities: { model: "claude-haiku-4-5", timestamp: "' + ts + '", confidence: 0.80 }';

      var imageHtml = '';
      if (ogImage) {
        imageHtml = '<div style="margin-bottom:1rem"><img src="' + esc(ogImage) + '" style="max-width:100%;max-height:200px;border-radius:8px;border:1px solid var(--hairline)" onerror="this.style.display=\'none\'" /></div>';
      }

      body.innerHTML = imageHtml +
        '<div><div class="aco-section-label">Summary</div>' +
        '<div class="aco-summary">' + esc(data.summary || '') + '</div></div>' +
        '<div class="aco-meta-row">' +
        '<span class="aco-badge aco-badge-classification">' + esc(data.classification || '') + '</span>' +
        '<span class="aco-badge aco-badge-lang">' + esc(data.language || 'en') + '</span>' +
        '</div>' +
        tagsHtml + entitiesHtml +
        '<div><div class="aco-section-label">Token counts (estimated)</div>' +
        '<div class="aco-tokens"><div class="aco-token-item"><span class="aco-token-label">approximate</span><span class="aco-token-value">' + approxTokens.toLocaleString() + '</span></div></div></div>' +
        '<div><button class="aco-prov-toggle" onclick="toggleProv(this)"><span class="arrow">&#9658;</span> Provenance</button>' +
        '<div class="aco-prov-content">tags:     { model: "claude-haiku-4-5", confidence: 0.85 }\nsummary:  { model: "claude-haiku-4-5", confidence: 0.85 }\nentities: { model: "claude-haiku-4-5", confidence: 0.80 }</div></div>' +
        '<div style="display:flex;justify-content:flex-end">' +
        '<button class="aco-yaml-toggle" onclick="toggleYaml(this)">&lt;/&gt; Raw YAML</button></div>' +
        '<div class="aco-yaml-block"><pre>' + esc(rawYaml) + '</pre></div>' +
        buildEconomicsHtml(approxTokens, 200);
    }

    function esc(s) {
      return String(s)
        .replace(/&/g,'&amp;')
        .replace(/</g,'&lt;')
        .replace(/>/g,'&gt;')
        .replace(/"/g,'&quot;')
        .replace(/'/g,'&#39;');
    }
  </script>

</body>
</html>
